# Copy to `.env` (gitignored) and fill in. This app reads secrets from ENV — NO Rails
# credentials / master.key, no dotenv gem. The `.env` is loaded at the shell level
# (e.g. oh-my-zsh's `dotenv` plugin sources it on `cd`), so the vars are already in ENV
# when you run rails/rspec. All values are OPTIONAL locally (Rails generates a dev
# secret_key_base; Postgres connects via the local socket); REQUIRED in production.

# Signs JWTs and Rails internals. REQUIRED in production.
# Generate with:  bin/rails secret   (or: openssl rand -hex 64)
# SECRET_KEY_BASE=

# Database connection (optional in dev if a local Postgres is reachable on the default socket).
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/backlogzy_development

# Comma-separated CORS origins allowed to call the API (defaults to http://localhost:5173).
# CORS_ORIGINS=http://localhost:5173

# Scaleway Object Storage (S3) — direct-to-S3 file uploads (presigned URLs). Required for
# uploads to work (dev included, since files go straight to the bucket). Bucket needs CORS
# allowing PUT from the SPA origin.
# SCALEWAY_ACCESS_KEY=
# SCALEWAY_SECRET_KEY=
# SCALEWAY_BUCKET_NAME=
# SCALEWAY_REGION=fr-par

# Transactional email (Scaleway TEM over SMTP). Login = Project ID, password = an API
# secret key. The sending domain must be verified in Scaleway TEM.
# SMTP_ADDRESS=smtp.tem.scaleway.com
# SMTP_PORT=587
# SMTP_USERNAME=        # your Scaleway Project ID
# SMTP_PASSWORD=        # a Scaleway API secret key
# SMTP_DOMAIN=roadmapper.fr
# MAIL_FROM=noreply@roadmapper.fr
# FRONT_URL=http://localhost:5173   # base URL used in email + OAuth redirects

# OAuth (login only). Create the apps in Google Cloud / GitHub; callback URLs are
# <API>/auth/google_oauth2/callback and <API>/auth/github/callback.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Billing — Lemon Squeezy (Merchant of Record). API key + store id enable hosted
# checkout/portal; the webhook secret verifies POST /webhooks/lemon_squeezy.
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
